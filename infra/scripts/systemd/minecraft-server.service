[Unit]
Description=Minecraft Server (Hardcore)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/minecraft-server
ExecStart=/usr/bin/java -Xmx2G -Xms1G -jar server.jar nogui
Restart=always
RestartSec=10
CPUAffinity=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
