# LLM
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# YouTube — 配信枠自動管理（3つそろえれば Live API で枠作成）
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# 上記が空のとき必須: 固定ストリームキー
# YOUTUBE_STREAM_KEY=
YOUTUBE_CHANNEL_ID=

# 任意（自動管理時）
# YOUTUBE_CATEGORY_ID=20
# YOUTUBE_TITLE_TEMPLATE=【AI Minecraft】星守レイのハードコア生存実験 #Gen{世代番号}
# YOUTUBE_DESCRIPTION_TEMPLATE=第{世代番号}世代\n最高: {最高記録}\n累計死亡: {累計死亡}

# Minecraft
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565

# VOICEVOX
VOICEVOX_HOST=http://localhost:50021
# VOICEVOX_SPEAKER_ID=23

# Database
DB_PATH=./data/state.db

# Dashboard
DASHBOARD_PORT=8080
